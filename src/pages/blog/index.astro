---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf()
);
---
<Layout title="Guías de skincare — Miranda Glow" description="Guías, comparativas y rutinas de cuidado de la piel explicadas con criterio.">
  <section class="blog-index wrap">
    <header class="bi-head">
      <h1>Guías de skincare</h1>
      <p>Comparativas, rutinas y respuestas claras. Sin postureo, por ingredientes.</p>
    </header>
    <div class="posts">
      {posts.map((post) => (
        <a class="post-card" href={`/blog/${post.slug}`}>
          <span class="thumb" aria-hidden="true"></span>
          <span class="pc-body">
            {post.data.concern && <span class="tag">{post.data.concern}</span>}
            <h2>{post.data.titulo}</h2>
            <p>{post.data.descripcion}</p>
            <time>{post.data.fecha.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          </span>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .blog-index{padding:70px 28px 100px}
  .bi-head{text-align:center;max-width:620px;margin:0 auto 56px}
  .bi-head h1{font-size:clamp(2.2rem,5vw,3.4rem);margin-bottom:14px}
  .bi-head p{color:var(--ink-soft)}
  .posts{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:26px;max-width:1180px;margin:0 auto}
  .post-card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;text-decoration:none;color:var(--ink);transition:transform .3s, box-shadow .3s}
  .post-card:hover{transform:translateY(-6px);box-shadow:var(--shadow)}
  .thumb{display:block;height:170px;background:linear-gradient(135deg,var(--sage),var(--accent))}
  .pc-body{display:block;padding:24px}
  .tag{display:inline-block;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:10px}
  .pc-body h2{font-size:1.35rem;margin-bottom:10px;line-height:1.2}
  .pc-body p{font-size:.95rem;color:var(--ink-soft);margin-bottom:14px}
  .pc-body time{font-size:.82rem;color:var(--ink-soft)}
</style>
